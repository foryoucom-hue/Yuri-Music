<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Yuri Music</title>

  <meta name="description" content="Yuri Music adalah bot musik Discord modern dengan audio berkualitas tinggi, kontrol interaktif, playlist canggih, filter audio, dan lirik real-time untuk server Discord kamu.">
  <meta name="keywords" content="Yuri Music, Discord Music Bot, Bot Musik Discord, Spotify Bot, YouTube Music Bot, Discord Bot Indonesia">
  <meta name="author" content="Yuri Music">
  <meta name="robots" content="index, follow">
  <meta name="theme-color" content="#7c3aed">
  <link rel="canonical" href="https://yurimusic.xyz/">

  <!-- Open Graph / Embed Preview -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="Yuri Music">
  <meta property="og:description" content="Bot musik Discord modern dengan kualitas audio jernih, kontrol interaktif, playlist canggih, filter audio, dan lirik real-time.">
  <meta property="og:url" content="https://yurimusic.xyz/">
  <meta property="og:site_name" content="Yuri Music">
  <meta property="og:locale" content="id_ID">
  <meta property="og:image" content="https://yurimusic.xyz/pp.jpg">
  <meta property="og:image:secure_url" content="https://yurimusic.xyz/pp.jpg">
  <meta property="og:image:alt" content="Yuri Music - Discord Music Bot">
  <meta property="og:image:type" content="image/jpeg">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Yuri Music">
  <meta name="twitter:description" content="Bot musik Discord modern dengan kualitas audio jernih, kontrol interaktif, playlist canggih, filter audio, dan lirik real-time.">
  <meta name="twitter:image" content="https://yurimusic.xyz/pp.jpg">

  <!-- Optional favicon -->
  <link rel="icon" type="image/jpeg" href="https://yurimusic.xyz/pp.jpg">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Roboto:wght@300;400;700&display=swap"
    rel="stylesheet">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      min-height: 100vh;
      background: #000000;
      font-family: 'Roboto', system-ui, sans-serif;
      overflow-x: hidden;
      overflow-y: auto;
      position: relative;
      color: #fff;
      opacity: 0;
      transition: opacity 1.2s ease;
    }

    body.loaded {
      opacity: 1;
    }

    /* === PRELOADER === */
    #preloader {
      position: fixed;
      inset: 0;
      background: #000;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      z-index: 9999;
      transition: opacity 0.6s ease, visibility 0.6s ease;
    }

    #preloader.hidden {
      opacity: 0;
      visibility: hidden;
    }

    .loader-logo {
      font-family: 'Orbitron', sans-serif;
      font-size: 6rem;
      font-weight: 900;
      background: linear-gradient(90deg, #00f0ff, #00aaff, #0066ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      text-shadow: 0 0 30px rgba(0, 240, 255, 0.7);
      animation: pulse 2s infinite alternate;
      margin-bottom: 20px;
    }

    @keyframes pulse {
      0% { transform: scale(1); opacity: 0.8; }
      100% { transform: scale(1.08); opacity: 1; }
    }

    .loader-text {
      font-size: 1.8rem;
      color: #a78bfa;
      letter-spacing: 4px;
      margin-bottom: 30px;
    }

    .loader-bar {
      width: 300px;
      height: 6px;
      background: rgba(168, 139, 250, 0.2);
      border-radius: 3px;
      overflow: hidden;
    }

    .loader-progress {
      width: 0;
      height: 100%;
      background: linear-gradient(90deg, #a78bfa, #c084fc);
      animation: loading 1.8s ease-in-out forwards;
    }

    @keyframes loading {
      0% { width: 0; }
      100% { width: 100%; }
    }

    /* Navbar */
    .navbar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 70px;
      background: rgba(5, 5, 15, 0.88);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(120, 100, 255, 0.12);
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 50px;
      opacity: 0;
      transform: translateY(-20px);
      transition: all 0.6s ease 1.8s;
    }

    .navbar.loaded {
      opacity: 1;
      transform: translateY(0);
    }

    .logo {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.9rem;
      font-weight: 900;
      background: linear-gradient(90deg, #c084fc, #7c3aed, #a78bfa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      text-shadow: 0 0 15px rgba(168, 85, 247, 0.6);
      letter-spacing: 3px;
    }

    .nav-menu {
      display: flex;
      gap: 50px;
      align-items: center;
    }

    .nav-menu a {
      color: #d0d0ff;
      text-decoration: none;
      font-size: 1.1rem;
      font-weight: 500;
      transition: all 0.3s ease;
      position: relative;
    }

    .nav-menu a:hover {
      color: #ffffff;
      text-shadow: 0 0 10px rgba(255, 255, 255, 0.7);
    }

    .nav-menu a::after {
      content: '';
      position: absolute;
      width: 0;
      height: 2px;
      bottom: -8px;
      left: 0;
      background: linear-gradient(90deg, #c084fc, #a78bfa);
      transition: width 0.4s ease;
    }

    .nav-menu a:hover::after {
      width: 100%;
    }

    .nav-actions {
      display: flex;
      gap: 20px;
      align-items: center;
    }

    .btn-action {
      padding: 10px 28px;
      border-radius: 50px;
      font-size: 1rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.3s ease;
    }

    .btn-premium {
      background: linear-gradient(135deg, #7c3aed, #c084fc);
      color: white;
      box-shadow: 0 0 20px rgba(168, 85, 247, 0.5);
    }

    .btn-premium:hover {
      transform: translateY(-3px);
      box-shadow: 0 0 35px rgba(168, 85, 247, 0.8);
    }

    .btn-support {
      background: transparent;
      color: #d0d0ff;
      border: 1px solid rgba(168, 85, 247, 0.5);
    }

    .btn-support:hover {
      background: rgba(168, 85, 247, 0.12);
      color: white;
      border-color: #c084fc;
    }

    .btn-login {
      padding: 10px 28px;
      background: #5865F2;
      color: white;
      border-radius: 50px;
      font-size: 1rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.3s ease;
      box-shadow: 0 0 20px rgba(88, 101, 242, 0.5);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .btn-login:hover {
      background: #4752C4;
      transform: translateY(-3px);
      box-shadow: 0 0 35px rgba(88, 101, 242, 0.8);
    }

    .user-info {
      display: flex;
      align-items: center;
      gap: 15px;
      color: #d0d0ff;
      font-weight: 600;
    }

    .user-avatar {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      background: linear-gradient(135deg, #c084fc, #7c3aed);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      border: 2px solid rgba(168, 85, 247, 0.5);
    }

    .btn-logout {
      padding: 8px 22px;
      background: transparent;
      color: #ff6b6b;
      border: 1px solid #ff6b6b;
      border-radius: 50px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      font-size: 0.95rem;
    }

    .btn-logout:hover {
      background: rgba(255, 107, 107, 0.15);
      transform: translateY(-2px);
    }

    /* Dropdown */
    .nav-dropdown {
      position: relative;
      display: flex;
      align-items: center;
    }

    .nav-dropbtn {
      background: transparent;
      border: none;
      color: #d0d0ff;
      font-size: 1.1rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.3s ease;
      position: relative;
      padding: 0;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .nav-dropbtn:hover {
      color: #ffffff;
      text-shadow: 0 0 10px rgba(255, 255, 255, 0.7);
    }

    .nav-dropbtn::after {
      content: '';
      position: absolute;
      width: 0;
      height: 2px;
      bottom: -8px;
      left: 0;
      background: linear-gradient(90deg, #c084fc, #a78bfa);
      transition: width 0.4s ease;
    }

    .nav-dropdown:hover .nav-dropbtn::after {
      width: 100%;
    }

    .dropdown-panel {
      position: absolute;
      top: calc(100% + 18px);
      left: 0;
      width: 340px;
      padding: 14px;
      border-radius: 14px;
      background: rgba(10, 10, 18, 0.92);
      border: 1px solid rgba(168, 85, 247, 0.20);
      box-shadow: 0 25px 80px rgba(0, 0, 0, 0.70);
      backdrop-filter: blur(14px);
      transform: translateY(-10px);
      opacity: 0;
      visibility: hidden;
      transition: all 0.25s ease;
      z-index: 2000;
    }

    .nav-dropdown.open .dropdown-panel {
      transform: translateY(0);
      opacity: 1;
      visibility: visible;
    }

    .dropdown-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 12px 12px;
      border-radius: 12px;
      text-decoration: none;
      transition: all 0.25s ease;
    }

    .dropdown-item:hover {
      background: rgba(168, 85, 247, 0.10);
      border: 1px solid rgba(168, 85, 247, 0.18);
    }

    .dropdown-ico {
      width: 38px;
      height: 38px;
      border-radius: 10px;
      background: rgba(168, 85, 247, 0.12);
      border: 1px solid rgba(168, 85, 247, 0.22);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      color: #fff;
      flex: 0 0 auto;
    }

    .dropdown-text {
      display: flex;
      flex-direction: column;
      gap: 3px;
    }

    .dropdown-title {
      font-weight: 700;
      color: #eaeaff;
      font-size: 1.05rem;
    }

    .dropdown-sub {
      color: #9aa0c6;
      font-size: 0.92rem;
    }

    /* Stars & Meteor */
    .stars {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: -1;
    }

    .star {
      position: absolute;
      background: #ffffff;
      border-radius: 50%;
      box-shadow: 0 0 8px rgba(255, 255, 255, 0.8), 0 0 16px rgba(255, 255, 255, 0.4);
      animation: twinkle 6s infinite alternate;
      opacity: 0.9;
    }

    @keyframes twinkle {
      0%, 100% { opacity: 0.5; transform: scale(0.8); }
      50% { opacity: 1; transform: scale(1.2); }
    }

    .meteor {
      position: absolute;
      width: 5px;
      height: 5px;
      background: #ffffff;
      border-radius: 50%;
      box-shadow: 0 0 20px 8px rgba(255,255,255,0.95), 0 0 50px 15px rgba(255,255,255,0.7), 0 0 90px 30px rgba(255,255,255,0.4);
      transform: translate(-50%, -50%) rotate(45deg);
      pointer-events: none;
      animation: meteor linear forwards;
    }

    .meteor::after {
      content: '';
      position: absolute;
      top: 50%;
      left: -220px;
      width: 220px;
      height: 3.5px;
      background: linear-gradient(to left, transparent, rgba(255,255,255,0.9), rgba(255,255,255,0.6));
      transform: translateY(-50%);
      opacity: 0.9;
      filter: blur(1.8px);
    }

    .meteor::before {
      content: '';
      position: absolute;
      top: 50%;
      left: -300px;
      width: 300px;
      height: 2.5px;
      background: linear-gradient(to left, transparent, rgba(255,255,255,0.5));
      transform: translateY(-50%);
      opacity: 0.6;
      filter: blur(4px);
    }

    @keyframes meteor {
      0% { transform: translate(-50%, -50%) translate(0, 0) rotate(45deg); opacity: 1; }
      100% { transform: translate(-50%, -50%) translate(-1200px, 1200px) rotate(45deg); opacity: 0; }
    }

    /* Header text */
    .header-text {
      position: relative;
      top: 140px;
      left: 8%;
      z-index: 5;
      max-width: 700px;
      padding: 0 20px;
      text-align: center;
    }

    .title {
      font-family: 'Orbitron', sans-serif;
      font-size: 5.5rem;
      font-weight: 900;
      letter-spacing: 8px;
      background: linear-gradient(90deg, #ffffff, #e0e0ff, #ffffff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-size: 200% auto;
      animation: gradientFlow 8s linear infinite;
      text-shadow: 0 0 20px rgba(255, 255, 255, 0.6), 0 0 40px rgba(255, 255, 255, 0.3);
      white-space: nowrap;
    }

    @keyframes gradientFlow {
      0% { background-position: 0% center; }
      100% { background-position: 200% center; }
    }

    .subtitle {
      font-family: 'Orbitron', sans-serif;
      font-size: 2.8rem;
      font-weight: 900;
      color: #d0d0ff;
      margin-top: 20px;
      letter-spacing: 4px;
      text-shadow: 0 0 25px rgba(168, 139, 250, 0.8), 0 0 50px rgba(168, 139, 250, 0.4);
      text-align: center;
      background: linear-gradient(90deg, #a78bfa, #c084fc, #7c3aed);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      overflow: hidden;
      white-space: nowrap;
      border-right: 0.15em solid #a78bfa;
      display: inline-block;
      animation: typing-delete 8s steps(40) infinite, blink-caret 0.75s step-end infinite;
    }

    @keyframes typing-delete {
      0% { width: 0; }
      25% { width: 100%; }
      50% { width: 100%; }
      75% { width: 0; }
      100% { width: 0; }
    }

    @keyframes blink-caret {
      from, to { border-color: transparent; }
      50% { border-color: #a78bfa; }
    }

    .description {
      margin-top: 30px;
      font-size: 1.3rem;
      line-height: 1.7;
      color: #cccccc;
      max-width: 650px;
      text-shadow: 0 0 10px rgba(255, 255, 255, 0.2);
      text-align: center;
    }

    .description strong {
      color: #ffffff;
      text-shadow: 0 0 12px rgba(255, 255, 255, 0.6);
    }

    .buttons {
      margin-top: 50px;
      display: flex;
      gap: 30px;
      justify-content: center;
    }

    .btn {
      padding: 16px 40px;
      font-size: 1.4rem;
      font-weight: 700;
      text-decoration: none;
      border-radius: 50px;
      transition: all 0.4s ease;
      cursor: pointer;
      border: 2px solid rgba(255, 255, 255, 0.3);
    }

    .btn-primary {
      background: linear-gradient(135deg, #7c3aed, #a78bfa);
      color: white;
      box-shadow: 0 0 25px rgba(168, 85, 247, 0.5);
    }

    .btn-primary:hover {
      transform: translateY(-4px);
      box-shadow: 0 0 40px rgba(168, 85, 247, 0.8);
      border-color: #d8b4fe;
    }

    .btn-secondary {
      background: transparent;
      color: #e0e0ff;
      box-shadow: 0 0 25px rgba(255, 255, 255, 0.2);
    }

    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.08);
      box-shadow: 0 0 35px rgba(255, 255, 255, 0.4);
      border-color: rgba(255, 255, 255, 0.6);
    }

    /* Profile */
    .profile-container {
      position: absolute;
      top: 280px;
      right: 150px;
      z-index: 10;
    }

    .profile {
      width: 700px;
      height: 700px;
      border-radius: 50%;
      object-fit: cover;
      border: 6px solid rgba(255, 255, 255, 0.25);
      box-shadow: 0 0 50px rgba(255,255,255,0.5), 0 0 100px rgba(255,255,255,0.25), inset 0 0 40px rgba(0,0,0,0.8);
      transition: all 0.5s ease;
    }

    .profile:hover {
      transform: scale(1.04);
      box-shadow: 0 0 80px rgba(255,255,255,0.8), 0 0 140px rgba(255,255,255,0.4), inset 0 0 40px rgba(0,0,0,0.8);
    }

    /* Stats Bar */
    .stats-bar {
      position: relative;
      top: 500px;
      left: 50%;
      transform: translateX(-50%);
      width: 90%;
      max-width: 1900px;
      background: rgba(15, 10, 45, 0.75);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(168, 85, 247, 0.35);
      border-radius: 16px;
      padding: 50px 80px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
      z-index: 9;
      margin-bottom: 400px;
    }

    .stat-item {
      display: flex;
      align-items: center;
      gap: 14px;
      font-size: 1.15rem;
      color: #d0d0ff;
    }

    .stat-icon {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: linear-gradient(135deg, #7c3aed, #c084fc);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      box-shadow: 0 0 18px rgba(168, 85, 247, 0.5);
    }

    .stat-divider {
      width: 1px;
      height: 50px;
      background: rgba(168, 85, 247, 0.3);
    }

    .stat-number {
      font-weight: 700;
      color: #ffffff;
      font-size: 1.5rem;
    }

    /* ======= MUSIC INFO SECTION ======= */
    .music-info-section {
      padding: 520px 4vw 80px;
      max-width: 100%;
      width: 100%;
      margin: 0 auto;
      position: relative;
      z-index: 2;
    }

    .section-label {
      display: inline-block;
      background: rgba(168, 85, 247, 0.15);
      border: 1px solid rgba(168, 85, 247, 0.4);
      border-radius: 50px;
      padding: 8px 24px;
      font-size: 1rem;
      font-weight: 700;
      color: #c084fc;
      letter-spacing: 2px;
      margin-bottom: 20px;
    }

    .section-heading {
      font-family: 'Orbitron', sans-serif;
      font-size: 3.4rem;
      font-weight: 900;
      background: linear-gradient(90deg, #ffffff, #d0d0ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 16px;
      line-height: 1.2;
    }

    .section-desc {
      font-size: 1.2rem;
      color: #a0a0c0;
      line-height: 1.7;
      max-width: 520px;
    }

    .music-row {
      display: flex;
      align-items: center;
      gap: 60px;
      opacity: 0;
      transform: translateY(60px);
      transition: all 0.9s cubic-bezier(0.22, 1, 0.36, 1);
      max-width: 30000px;
      margin-left: auto;
      margin-right: auto;
      margin-bottom: 250px;
    }

    .music-row.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .music-row.reverse {
      flex-direction: row-reverse;
    }

    .music-row-text {
      flex: 1;
      min-width: 280px;
      padding: 0 20px;
    }

    .music-row-visual {
      flex: 0.7;
      min-width: 340px;
      position: relative;
    }

    .discord-embed {
      background: #2b2d31;
      border-radius: 12px;
      border-left: 4px solid #a78bfa;
      padding: 80px 70px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.7);
      position: relative;
      overflow: hidden;
    }

    .discord-embed::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 80% 20%, rgba(168, 85, 247, 0.08), transparent 60%);
    }

    .discord-embed-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
    }

    .discord-bot-icon {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, #a78bfa, #7c3aed);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      font-weight: 700;
      color: white;
    }

    .discord-bot-name {
      font-weight: 700;
      color: #a78bfa;
      font-size: 1rem;
    }

    .discord-bot-badge {
      background: #5865F2;
      color: white;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 4px;
      letter-spacing: 0.5px;
    }

    .discord-bot-time {
      color: #72767d;
      font-size: 0.85rem;
      margin-left: auto;
    }

    .embed-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 8px;
    }

    .embed-content {
      color: #b9bbbe;
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .embed-fields {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-top: 16px;
    }

    .embed-field {
      background: rgba(255,255,255,0.04);
      border-radius: 8px;
      padding: 10px 14px;
    }

    .embed-field-name {
      font-size: 0.8rem;
      font-weight: 700;
      color: #a78bfa;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 4px;
    }

    .embed-field-value {
      font-size: 0.95rem;
      color: #dcddde;
    }

    .embed-progress {
      margin-top: 16px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .progress-bar {
      flex: 1;
      height: 6px;
      background: rgba(255,255,255,0.1);
      border-radius: 3px;
      overflow: hidden;
    }

    .progress-fill {
      width: 45%;
      height: 100%;
      background: linear-gradient(90deg, #a78bfa, #c084fc);
      border-radius: 3px;
      position: relative;
    }

    .progress-fill::after {
      content: '';
      position: absolute;
      right: -4px;
      top: 50%;
      transform: translateY(-50%);
      width: 12px;
      height: 12px;
      background: #fff;
      border-radius: 50%;
      box-shadow: 0 0 8px rgba(168, 85, 247, 0.8);
    }

    .progress-time {
      color: #72767d;
      font-size: 0.85rem;
      white-space: nowrap;
    }

    .embed-thumbnail {
      position: absolute;
      top: 20px;
      right: 20px;
      width: 70px;
      height: 70px;
      border-radius: 8px;
      object-fit: cover;
      box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    }

    .embed-buttons {
      display: flex;
      gap: 10px;
      margin-top: 16px;
      flex-wrap: wrap;
    }

    .embed-btn {
      background: rgba(168, 85, 247, 0.15);
      border: 1px solid rgba(168, 85, 247, 0.3);
      border-radius: 6px;
      padding: 6px 16px;
      color: #c084fc;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .embed-btn:hover {
      background: rgba(168, 85, 247, 0.3);
    }

    .embed-btn.green {
      background: rgba(74, 222, 128, 0.15);
      border-color: rgba(74, 222, 128, 0.3);
      color: #4ade80;
    }

    .embed-btn.red {
      background: rgba(255, 107, 107, 0.15);
      border-color: rgba(255, 107, 107, 0.3);
      color: #ff6b6b;
    }

    .float-deco {
      position: absolute;
      pointer-events: none;
    }

    .float-note {
      font-size: 3rem;
      opacity: 0.25;
      animation: floatNote 4s ease-in-out infinite alternate;
    }

    @keyframes floatNote {
      0% { transform: translateY(0) rotate(-10deg); }
      100% { transform: translateY(-20px) rotate(10deg); }
    }

    .features-section {
      padding: 60px 3vw 140px;
      max-width: 100%;
      width: 100%;
      margin: 0 auto;
      position: relative;
      z-index: 2;
    }

    .features-title {
      font-family: 'Orbitron', sans-serif;
      font-size: 4.2rem;
      margin-bottom: 16px;
      background: linear-gradient(90deg, #a78bfa, #c084fc, #7c3aed);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      text-shadow: 0 0 35px rgba(168, 85, 247, 0.5);
      text-align: center;
    }

    .features-subtitle {
      font-size: 1.5rem;
      color: #b0b0ff;
      margin-bottom: 80px;
      text-align: center;
    }

    .feat-grid {
      display: flex;
      flex-direction: column;
      gap: 100px;
      max-width: 1950px;
      margin: 0 auto;
    }

    .feat-card {
      background: rgba(28, 22, 55, 0.55);
      backdrop-filter: blur(18px);
      border: 1px solid rgba(168, 85, 247, 0.22);
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 10px 50px rgba(0, 0, 0, 0.5);
      transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);
      opacity: 0;
      transform: translateY(50px);
      display: flex;
      flex-direction: row;
      align-items: stretch;
    }

    .feat-card:nth-child(even) {
      flex-direction: row-reverse;
    }

    .feat-card.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .feat-card:hover {
      border-color: rgba(168, 85, 247, 0.6);
      box-shadow: 0 20px 70px rgba(168, 85, 247, 0.25);
    }

    .feat-img-wrap {
      width: 850px;
      min-width: 0px;
      flex-shrink: 0;
      overflow: hidden;
      position: relative;
      background: rgba(20,15,50,0.85);
      aspect-ratio: 16 / 9;
    }

    .feat-card:nth-child(odd) .feat-img-wrap {
      border-right: 1px solid rgba(168, 85, 247, 0.15);
    }

    .feat-card:nth-child(even) .feat-img-wrap {
      border-left: 1px solid rgba(168, 85, 247, 0.15);
    }

    .feat-img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
      display: block;
    }

    .feat-card:hover .feat-img-wrap img {
      transform: scale(1.06);
    }

    .feat-img-overlay {
      position: absolute;
      inset: 0;
    }

    .feat-card:nth-child(odd) .feat-img-overlay {
      background: linear-gradient(to right, transparent 55%, rgba(28,22,55,0.65) 100%);
    }

    .feat-card:nth-child(even) .feat-img-overlay {
      background: linear-gradient(to left, transparent 55%, rgba(28,22,55,0.65) 100%);
    }

    .feat-badge {
      position: absolute;
      top: 18px;
      left: 18px;
      background: rgba(168, 85, 247, 0.85);
      backdrop-filter: blur(8px);
      border-radius: 50px;
      padding: 6px 18px;
      font-size: 0.88rem;
      font-weight: 700;
      color: #fff;
      letter-spacing: 1px;
      display: flex;
      align-items: center;
      gap: 6px;
      z-index: 2;
    }

    .feat-right {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 56px 64px;
    }

    .feat-tag {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(168, 85, 247, 0.12);
      border: 1px solid rgba(168, 85, 247, 0.35);
      border-radius: 50px;
      padding: 6px 18px;
      font-size: 0.88rem;
      font-weight: 700;
      color: #c084fc;
      letter-spacing: 1.5px;
      margin-bottom: 22px;
      width: fit-content;
    }

    .feat-title {
      font-family: 'Orbitron', sans-serif;
      font-size: 2.4rem;
      font-weight: 900;
      color: #ffffff;
      margin-bottom: 16px;
      line-height: 1.25;
    }

    .feat-desc {
      font-size: 1.1rem;
      color: #a0a0c0;
      line-height: 1.75;
      margin-bottom: 28px;
      max-width: 540px;
    }

    .feat-list {
      list-style: none;
      padding: 0;
      margin-bottom: 32px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .feat-list li {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 1rem;
      color: #c8c8e8;
    }

    .feat-list li span.ico {
      font-size: 1.15rem;
      flex-shrink: 0;
    }

    .feat-actions {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
    }

    .feat-btn {
      padding: 11px 28px;
      border-radius: 50px;
      font-weight: 700;
      font-size: 0.95rem;
      cursor: pointer;
      border: none;
      transition: all 0.3s ease;
    }

    .feat-btn-go {
      background: linear-gradient(135deg, #4ade80, #22c55e);
      color: #000;
      box-shadow: 0 0 18px rgba(74,222,128,0.4);
    }

    .feat-btn-go:hover {
      transform: translateY(-3px);
      box-shadow: 0 0 30px rgba(74,222,128,0.7);
    }

    .feat-btn-more {
      background: transparent;
      color: #a78bfa;
      border: 1px solid rgba(168, 85, 247, 0.4);
    }

    .feat-btn-more:hover {
      background: rgba(168, 85, 247, 0.1);
    }

    .footer-section {
      position: relative;
      background: rgba(10, 8, 20, 0.95);
      border-top: 1px solid rgba(168, 85, 247, 0.2);
      padding: 80px 60px 40px;
      margin-top: 80px;
      z-index: 10;
    }

    .footer-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 60px;
    }

    .footer-brand {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .footer-logo-container {
      width: 80px;
      height: 80px;
      border-radius: 20px;
      overflow: hidden;
      border: 2px solid rgba(168, 85, 247, 0.3);
      box-shadow: 0 0 20px rgba(168, 85, 247, 0.3);
      background: linear-gradient(135deg, #7c3aed, #c084fc);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
    }

    .footer-logo-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .footer-brand-info {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .footer-brand-name {
      font-family: 'Orbitron', sans-serif;
      font-size: 2rem;
      font-weight: 900;
      background: linear-gradient(90deg, #a78bfa, #c084fc);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      letter-spacing: 2px;
    }

    .footer-brand-tagline {
      font-size: 1rem;
      color: #9090b0;
    }

    .footer-stats {
      display: flex;
      gap: 60px;
      align-items: center;
    }

    .footer-stat {
      text-align: center;
    }

    .footer-stat-number {
      font-size: 2.5rem;
      font-weight: 700;
      color: #ffffff;
      font-family: 'Orbitron', sans-serif;
      margin-bottom: 8px;
    }

    .footer-stat-label {
      font-size: 0.95rem;
      color: #9090b0;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .footer-divider {
      width: 100%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(168, 85, 247, 0.3), transparent);
      margin: 60px 0;
    }

    .footer-content {
      display: flex;
      justify-content: space-between;
      gap: 100px;
      margin-bottom: 60px;
      max-width: 900px;
    }

    .footer-column { flex: 1; }

    .footer-heading {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.3rem;
      font-weight: 700;
      color: #ffffff;
      margin-bottom: 25px;
      letter-spacing: 1px;
    }

    .footer-links {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .footer-links li a {
      color: #b0b0d0;
      text-decoration: none;
      font-size: 1.05rem;
      transition: all 0.3s ease;
      display: inline-block;
    }

    .footer-links li a:hover {
      color: #ffffff;
      transform: translateX(5px);
      text-shadow: 0 0 10px rgba(255,255,255,0.5);
    }

    .footer-bottom {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 40px;
      border-top: 1px solid rgba(168, 85, 247, 0.15);
    }

    .footer-copyright { font-size: 1rem; color: #8080a0; }

    .footer-socials { display: flex; gap: 20px; align-items: center; }

    .footer-social-link {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: rgba(168, 85, 247, 0.1);
      border: 1px solid rgba(168, 85, 247, 0.3);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #b0b0d0;
      transition: all 0.35s ease;
      text-decoration: none;
    }

    .footer-social-link:hover {
      background: rgba(168, 85, 247, 0.25);
      border-color: rgba(168, 85, 247, 0.6);
      color: #ffffff;
      transform: translateY(-4px);
      box-shadow: 0 8px 25px rgba(168, 85, 247, 0.4);
    }

    @media (max-width: 1100px) {
      .profile-container { right: 20px; }
      .profile { width: 500px; height: 500px; }
      .header-text { max-width: 500px; }
      .title { font-size: 4rem; }
    }

    @media (max-width: 900px) {
      .navbar { padding: 0 20px; }
      .nav-menu { gap: 24px; }
      .nav-menu a { font-size: 0.95rem; }

      .profile-container {
        position: relative;
        top: 0;
        right: 0;
        display: flex;
        justify-content: center;
        margin-top: 20px;
      }

      .profile { width: 280px; height: 280px; }

      .header-text {
        position: relative;
        top: 80px;
        left: 0;
        width: 100%;
        max-width: 100%;
        padding: 0 20px;
        text-align: center;
      }

      .title { font-size: 2.8rem; letter-spacing: 4px; white-space: normal; }
      .subtitle { font-size: 1.5rem; letter-spacing: 2px; white-space: normal; }
      .description { font-size: 1.05rem; }

      .stats-bar {
        top: 420px;
        flex-wrap: wrap;
        gap: 20px;
        justify-content: center;
        padding: 18px 20px;
      }

      .stat-divider { display: none; }

      .music-info-section { padding: 500px 20px 60px; }
      .music-row, .music-row.reverse {
        flex-direction: column;
        gap: 40px;
        margin-bottom: 80px;
      }

      .section-heading { font-size: 2.2rem; }

      .features-section { padding: 40px 16px 80px; }
      .features-title { font-size: 2.6rem; }
      .feat-grid { gap: 24px; }
      .feat-card, .feat-card:nth-child(even) { flex-direction: column; }
      .feat-img-wrap { width: 100% !important; min-width: 0 !important; aspect-ratio: 9 / 16 !important; max-height: 380px; border-right: none !important; border-left: none !important; border-bottom: 1px solid rgba(168,85,247,0.15); }
      .feat-card:nth-child(odd) .feat-img-overlay, .feat-card:nth-child(even) .feat-img-overlay { background: linear-gradient(to bottom, transparent 50%, rgba(28,22,55,0.85) 100%) !important; }
      .feat-right { padding: 28px 24px; }
      .feat-title { font-size: 1.8rem; }

      .footer-section { padding: 60px 20px 30px; }
      .footer-top { flex-direction: column; gap: 40px; text-align: center; }
      .footer-brand { flex-direction: column; }
      .footer-stats { gap: 30px; flex-wrap: wrap; justify-content: center; }
      .footer-content { flex-direction: column; gap: 40px; }
      .footer-bottom { flex-direction: column; gap: 20px; text-align: center; }
    }

    @media (max-width: 600px) {
      .nav-menu { display: none; }
      .logo { font-size: 1.4rem; }
      .title { font-size: 2.2rem; }
      .subtitle { font-size: 1.2rem; }
      .btn { padding: 12px 26px; font-size: 1.1rem; }
      .buttons { flex-direction: column; align-items: center; gap: 16px; }
      .loader-logo { font-size: 3.5rem; }
      .loader-text { font-size: 1.1rem; letter-spacing: 2px; }
      .music-info-section { padding: 400px 16px 40px; }
    }

    .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 8px;
    }

    .hamburger span {
      display: block;
      width: 26px;
      height: 2px;
      background: #d0d0ff;
      border-radius: 2px;
      transition: all 0.3s ease;
    }

    @media (max-width: 600px) {
      .hamburger { display: flex; }

      .mobile-menu {
        display: none;
        position: fixed;
        top: 70px;
        left: 0;
        right: 0;
        background: rgba(5, 5, 15, 0.98);
        backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(168, 85, 247, 0.2);
        padding: 20px;
        z-index: 999;
        flex-direction: column;
        gap: 16px;
      }

      .mobile-menu.open { display: flex; }

      .mobile-menu a {
        color: #d0d0ff;
        text-decoration: none;
        font-size: 1.1rem;
        font-weight: 500;
        padding: 10px 0;
        border-bottom: 1px solid rgba(168, 85, 247, 0.1);
      }
    }
  </style>
</head>

