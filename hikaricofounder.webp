  <div class="stars" id="stars"></div>

  <!-- Hero -->
  <section class="hero-section">
    <div class="hero-badge">🎵 MUSIC BOT</div>
    <h1 class="hero-title">YURI MUSIC</h1>
    <p class="hero-subtitle">
      Bot musik Discord terbaik dengan 25+ command lengkap. Putar lagu dari YouTube, Spotify, SoundCloud dan nikmati fitur playlist, filter, loop, dan masih banyak lagi!
    </p>
    <div class="hero-stats">
      <div class="hero-stat">
        <div class="hero-stat-number">25+</div>
        <div class="hero-stat-label">Commands</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-number">3</div>
        <div class="hero-stat-label">Platforms</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-number">24/7</div>
        <div class="hero-stat-label">Uptime</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-number">HQ</div>
        <div class="hero-stat-label">Audio</div>
      </div>
    </div>
  </section>

  <div class="features-container">

    <!-- Playback Core -->
    <div class="section-header">
      <div class="section-label">🎵 PLAYBACK</div>
      <h2 class="category-title"><span>🎶</span> Playback & Controls</h2>
      <p class="category-subtitle">Kontrol penuh atas musik yang diputar di voice channel kamu</p>
    </div>

    <div class="playback-grid" id="playbackGrid">
      <div class="feature-card highlight">
        <div class="card-top">
          <div class="feature-icon-wrap">▶️</div>
          <div class="card-header">
            <div class="feature-cmd">/play</div>
            <div class="feature-name">Play</div>
          </div>
        </div>
        <p class="feature-description">Putar lagu dari YouTube, Spotify, SoundCloud langsung di voice channel. Support URL dan pencarian kata kunci.</p>
        <div class="feature-tags">
          <span class="feature-tag">YouTube</span>
          <span class="feature-tag">Spotify</span>
          <span class="feature-tag">SoundCloud</span>
          <span class="feature-tag">URL & Search</span>
        </div>
      </div>

      <div class="feature-card">
        <div class="card-top">
          <div class="feature-icon-wrap">⏸️</div>
          <div class="card-header">
            <div class="feature-cmd">/pause</div>
            <div class="feature-name">Pause</div>
          </div>
        </div>
        <p class="feature-description">Pause lagu yang sedang diputar sementara. Gunakan /resume untuk melanjutkan dari posisi yang sama.</p>
        <div class="feature-tags">
          <span class="feature-tag">Toggle</span>
          <span class="feature-tag">Instant</span>
        </div>
      </div>

      <div class="feature-card">
        <div class="card-top">
          <div class="feature-icon-wrap">▶️</div>
          <div class="card-header">
            <div class="feature-cmd">/resume</div>
            <div class="feature-name">Resume</div>
          </div>
        </div>
        <p class="feature-description">Lanjutkan lagu yang di-pause dari posisi terakhir tanpa kehilangan progress.</p>
        <div class="feature-tags">
          <span class="feature-tag">Continue</span>
          <span class="feature-tag">No Skip</span>
        </div>
      </div>

      <div class="feature-card">
        <div class="card-top">
          <div class="feature-icon-wrap">⏹️</div>
          <div class="card-header">
            <div class="feature-cmd">/stop</div>
            <div class="feature-name">Stop</div>
          </div>
        </div>
        <p class="feature-description">Hentikan pemutaran musik dan hapus seluruh queue. Bot akan tetap stay di voice channel.</p>
        <div class="feature-tags">
          <span class="feature-tag">Clear Queue</span>
          <span class="feature-tag">Stay in VC</span>
        </div>
      </div>

      <div class="feature-card">
        <div class="card-top">
          <div class="feature-icon-wrap">⏭️</div>
          <div class="card-header">
            <div class="feature-cmd">/skip</div>
            <div class="feature-name">Skip</div>
          </div>
        </div>
        <p class="feature-description">Skip lagu saat ini dan langsung putar lagu berikutnya di queue secara instan.</p>
        <div class="feature-tags">
          <span class="feature-tag">Fast</span>
          <span class="feature-tag">Next Track</span>
        </div>
      </div>

      <div class="feature-card">
        <div class="card-top">
          <div class="feature-icon-wrap">⏩</div>
          <div class="card-header">
            <div class="feature-cmd">/skipto</div>
            <div class="feature-name">Skip To</div>
          </div>
        </div>
        <p class="feature-description">Langsung loncat ke nomor lagu tertentu di queue tanpa harus skip satu per satu.</p>
        <div class="feature-tags">
          <span class="feature-tag">Index Jump</span>
          <span class="feature-tag">Quick Nav</span>
        </div>
      </div>

      <div class="feature-card">
        <div class="card-top">
          <div class="feature-icon-wrap">⏮️</div>
          <div class="card-header">
            <div class="feature-cmd">/replay</div>
            <div class="feature-name">Replay</div>
          </div>
        </div>
        <p class="feature-description">Putar ulang lagu yang sedang diputar dari awal tanpa perlu mencari atau mengetik ulang.</p>
        <div class="feature-tags">
          <span class="feature-tag">Restart Track</span>
          <span class="feature-tag">One Click</span>
        </div>
      </div>

      <div class="feature-card">
        <div class="card-top">
          <div class="feature-icon-wrap">⏱️</div>
          <div class="card-header">
            <div class="feature-cmd">/seek</div>
            <div class="feature-name">Seek</div>
          </div>
        </div>
        <p class="feature-description">Loncat ke timestamp tertentu dalam lagu. Format: detik atau mm:ss untuk navigasi presisi.</p>
        <div class="feature-tags">
          <span class="feature-tag">Timestamp</span>
          <span class="feature-tag">mm:ss format</span>
        </div>
      </div>

      <div class="feature-card">
        <div class="card-top">
          <div class="feature-icon-wrap">🔊</div>
          <div class="card-header">
            <div class="feature-cmd">/volume</div>
            <div class="feature-name">Volume</div>
          </div>
        </div>
        <p class="feature-description">Atur volume bot dari 0 hingga 200. Default 100 untuk kualitas audio terbaik tanpa distorsi.</p>
        <div class="feature-tags">
          <span class="feature-tag">0-200%</span>
          <span class="feature-tag">Real-time</span>
        </div>
      </div>
    </div>

    <!-- Queue Management -->
    <div class="section-header" style="margin-top: 80px;">
      <div class="section-label">📋 QUEUE</div>
      <h2 class="category-title"><span>📋</span> Queue Management</h2>
      <p class="category-subtitle">Kelola antrian lagu dengan mudah dan fleksibel</p>
    </div>

    <div class="playback-grid">
      <div class="feature-card highlight">
        <div class="card-top">
          <div class="feature-icon-wrap">📋</div>
          <div class="card-header">
            <div class="feature-cmd">/queue</div>
            <div class="feature-name">Queue</div>
          </div>
        </div>
        <p class="feature-description">Lihat daftar lagu yang akan diputar berikutnya lengkap dengan durasi, nama, dan requester.</p>
        <div class="feature-tags">
          <span class="feature-tag">Full List</span>
          <span class="feature-tag">Duration</span>
          <span class="feature-tag">Requester</span>
        </div>
      </div>

      <div class="feature-card">
        <div class="card-top">
          <div class="feature-icon-wrap">🗑️</div>
          <div class="card-header">
            <div class="feature-cmd">/clear</div>
            <div class="feature-name">Clear</div>
          </div>
        </div>
        <p class="feature-description">Hapus semua lagu dari queue sekaligus. Lagu yang sedang diputar tidak akan terpengaruh.</p>
        <div class="feature-tags">
          <span class="feature-tag">Bulk Remove</span>
          <span class="feature-tag">Safe</span>
        </div>
      </div>

      <div class="feature-card">
        <div class="card-top">
          <div class="feature-icon-wrap">❌</div>
          <div class="card-header">
            <div class="feature-cmd">/remove</div>
            <div class="feature-name">Remove</div>
          </div>
        </div>
        <p class="feature-description">Hapus lagu tertentu dari queue berdasarkan posisi nomor antrian tanpa mengganggu lagu lain.</p>
        <div class="feature-tags">
          <span class="feature-tag">By Index</span>
          <span class="feature-tag">Selective</span>
        </div>
      </div>

      <div class="feature-card">
        <div class="card-top">
          <div class="feature-icon-wrap">🔀</div>
          <div class="card-header">
            <div class="feature-cmd">/shuffle</div>
            <div class="feature-name">Shuffle</div>
          </div>
        </div>
        <p class="feature-description">Acak urutan semua lagu dalam queue untuk pengalaman mendengarkan yang lebih variatif.</p>
        <div class="feature-tags">
          <span class="feature-tag">Random Order</span>
          <span class="feature-tag">One Click</span>
        </div>
      </div>

      <div class="feature-card">
        <div class="card-top">
          <div class="feature-icon-wrap">↕️</div>
          <div class="card-header">
            <div class="feature-cmd">/move</div>
            <div class="feature-name">Move</div>
          </div>
        </div>
        <p class="feature-description">Pindahkan lagu dari posisi satu ke posisi lain dalam queue untuk mengatur urutan sesuai keinginan.</p>
        <div class="feature-tags">
          <span class="feature-tag">Reorder</span>
          <span class="feature-tag">Drag & Drop</span>
        </div>
      </div>

      <div class="feature-card">
        <div class="card-top">
          <div class="feature-icon-wrap">🔁</div>
          <div class="card-header">
            <div class="feature-cmd">/loopqueue</div>
            <div class="feature-name">Loop Queue</div>
          </div>
        </div>
        <p class="feature-description">Ulangi semua lagu dalam queue secara terus-menerus. Setelah lagu terakhir, mulai lagi dari awal.</p>
        <div class="feature-tags">
          <span class="feature-tag">Repeat All</span>
          <span class="feature-tag">Endless Play</span>
        </div>
      </div>
    </div>

    <!-- Loop & 247 -->
    <div class="section-header" style="margin-top: 80px;">
      <div class="section-label">🔄 LOOP & 24/7</div>
      <h2 class="category-title"><span>🔄</span> Loop & Non-Stop</h2>
      <p class="category-subtitle">Kontrol mode pengulangan dan pemutaran tanpa henti</p>
    </div>

    <div class="playback-grid" style="grid-template-columns: repeat(3, 1fr);">
      <div class="feature-card highlight">
        <div class="card-top">
          <div class="feature-icon-wrap">🔂</div>
          <div class="card-header">
            <div class="feature-cmd">/loop</div>
            <div class="feature-name">Loop</div>
          </div>
        </div>
        <p class="feature-description">Ulangi lagu yang sedang diputar terus-menerus. Toggle on/off dengan satu command.</p>
        <div class="feature-tags">
          <span class="feature-tag">Single Track</span>
          <span class="feature-tag">Toggle</span>
          <span class="feature-tag">Infinite</span>
        </div>
      </div>

      <div class="feature-card highlight">
        <div class="card-top">
          <div class="feature-icon-wrap">⏰</div>
          <div class="card-header">
            <div class="feature-cmd">/247</div>
            <div class="feature-name">247 Mode</div>
          </div>
        </div>
        <p class="feature-description">Bot tetap stay di voice channel 24 jam 7 hari tanpa disconnect meski tidak ada yang mendengarkan.</p>
        <div class="feature-tags">
          <span class="feature-tag">Always On</span>
          <span class="feature-tag">No Timeout</span>
          <span class="feature-tag">Premium</span>
        </div>
      </div>

      <div class="feature-card">
        <div class="card-top">
          <div class="feature-icon-wrap">▶️</div>
          <div class="card-header">
            <div class="feature-cmd">/autoplay</div>
            <div class="feature-name">Autoplay</div>
          </div>
        </div>
        <p class="feature-description">Otomatis tambah lagu terkait ke queue ketika queue hampir habis berdasarkan lagu yang sedang diputar.</p>
        <div class="feature-tags">
          <span class="feature-tag">Smart Pick</span>
          <span class="feature-tag">Related Songs</span>
        </div>
      </div>
    </div>

    <!-- Playlist & Search -->
    <div class="section-header" style="margin-top: 80px;">
      <div class="section-label">📁 PLAYLIST & SEARCH</div>
      <h2 class="category-title"><span>📁</span> Playlist & Search</h2>
      <p class="category-subtitle">Kelola koleksi musik dan temukan lagu favoritmu</p>
    </div>

    <div class="playback-grid">
      <div class="feature-card highlight">
        <div class="card-top">
          <div class="feature-icon-wrap">📁</div>
          <div class="card-header">
            <div class="feature-cmd">/playlist</div>
            <div class="feature-name">Playlist</div>
          </div>
        </div>
        <p class="feature-description">Buat, simpan, dan putar playlist custom. Simpan kumpulan lagu favoritmu dan putar kapan saja.</p>
        <div class="feature-tags">
          <span class="feature-tag">Create</span>
          <span class="feature-tag">Save</span>
          <span class="feature-tag">Load</span>
          <span class="feature-tag">Share</span>
        </div>
      </div>

      <div class="feature-card">
        <div class="card-top">
          <div class="feature-icon-wrap">🔍</div>
          <div class="card-header">
            <div class="feature-cmd">/search</div>
            <div class="feature-name">Search</div>
          </div>
        </div>
        <p class="feature-description">Cari lagu dengan kata kunci dan pilih dari hasil pencarian. Tampilkan 10 hasil teratas untuk dipilih.</p>
        <div class="feature-tags">
          <span class="feature-tag">10 Results</span>
          <span class="feature-tag">Interactive</span>
          <span class="feature-tag">Multi-Platform</span>
        </div>
      </div>

      <div class="feature-card">
        <div class="card-top">
          <div class="feature-icon-wrap">🎵</div>
          <div class="card-header">
            <div class="feature-cmd">/nowplaying</div>
            <div class="feature-name">Now Playing</div>
          </div>
        </div>
        <p class="feature-description">Lihat info lengkap lagu yang sedang diputar: judul, durasi, progress bar, requester, dan thumbnail.</p>
        <div class="feature-tags">
          <span class="feature-tag">Progress Bar</span>
          <span class="feature-tag">Thumbnail</span>
          <span class="feature-tag">Embed</span>
        </div>
      </div>
    </div>

    <!-- Audio Filters -->
    <div class="section-header" style="margin-top: 80px;">
      <div class="section-label">🎛️ AUDIO</div>
      <h2 class="category-title"><span>🎛️</span> Audio Filters</h2>
      <p class="category-subtitle">Sesuaikan kualitas audio sesuai selera dengan berbagai filter</p>
    </div>

    <div class="feature-card" style="margin-bottom: 28px; opacity: 1; transform: none;">
      <div class="card-top">
        <div class="feature-icon-wrap">🎛️</div>
        <div class="card-header">
          <div class="feature-cmd">/filter</div>
          <div class="feature-name">Audio Filters</div>
        </div>
      </div>
      <p class="feature-description">Terapkan filter audio real-time untuk mengubah suara musik sesuai mood dan suasana yang kamu inginkan.</p>
      <div class="feature-tags">
        <span class="feature-tag">🔊 Bass Boost</span>
        <span class="feature-tag">🌙 Nightcore</span>
        <span class="feature-tag">🐌 Slowed</span>
        <span class="feature-tag">🎸 8D Audio</span>
        <span class="feature-tag">🎵 Vaporwave</span>
        <span class="feature-tag">📻 Lo-Fi</span>
        <span class="feature-tag">🎤 Karaoke</span>
        <span class="feature-tag">🔄 Rotation</span>
        <span class="feature-tag">📳 Tremolo</span>
        <span class="feature-tag">🌊 Vibrato</span>
        <span class="feature-tag">🎭 Distortion</span>
        <span class="feature-tag">↕️ Pitch Control</span>
      </div>
    </div>

    <!-- Voice & Help -->
    <div class="section-header" style="margin-top: 80px;">
      <div class="section-label">🎙️ VOICE & HELP</div>
      <h2 class="category-title"><span>🎙️</span> Voice & Help</h2>
      <p class="category-subtitle">Kelola koneksi bot dan dapatkan bantuan kapan saja</p>
    </div>

    <div class="playback-grid" style="grid-template-columns: repeat(3, 1fr);">
      <div class="feature-card">
        <div class="card-top">
          <div class="feature-icon-wrap">📥</div>
          <div class="card-header">
            <div class="feature-cmd">/join</div>
            <div class="feature-name">Join</div>
          </div>
        </div>
        <p class="feature-description">Bot masuk ke voice channel yang kamu tempati. Otomatis terdeteksi tanpa perlu menyebut nama channel.</p>
        <div class="feature-tags">
          <span class="feature-tag">Auto Detect</span>
          <span class="feature-tag">Instant</span>
        </div>
      </div>

      <div class="feature-card">
        <div class="card-top">
          <div class="feature-icon-wrap">📤</div>
          <div class="card-header">
            <div class="feature-cmd">/leave</div>
            <div class="feature-name">Leave</div>
          </div>
        </div>
        <p class="feature-description">Bot keluar dari voice channel dan membersihkan semua queue serta session yang aktif.</p>
