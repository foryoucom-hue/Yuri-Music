      <div class="commands-grid" id="commandsGrid">
        <div class="command-pill"><span class="cmd-icon">▶️</span><div class="cmd-info"><div class="cmd-name">/play</div><div class="cmd-desc">Putar lagu atau URL</div></div></div>
        <div class="command-pill"><span class="cmd-icon">⏸️</span><div class="cmd-info"><div class="cmd-name">/pause</div><div class="cmd-desc">Pause lagu</div></div></div>
        <div class="command-pill"><span class="cmd-icon">▶️</span><div class="cmd-info"><div class="cmd-name">/resume</div><div class="cmd-desc">Lanjutkan lagu</div></div></div>
        <div class="command-pill"><span class="cmd-icon">⏹️</span><div class="cmd-info"><div class="cmd-name">/stop</div><div class="cmd-desc">Stop & clear queue</div></div></div>
        <div class="command-pill"><span class="cmd-icon">⏭️</span><div class="cmd-info"><div class="cmd-name">/skip</div><div class="cmd-desc">Skip ke lagu berikutnya</div></div></div>
        <div class="command-pill"><span class="cmd-icon">⏩</span><div class="cmd-info"><div class="cmd-name">/skipto</div><div class="cmd-desc">Loncat ke nomor lagu</div></div></div>
        <div class="command-pill"><span class="cmd-icon">⏮️</span><div class="cmd-info"><div class="cmd-name">/replay</div><div class="cmd-desc">Ulang dari awal</div></div></div>
        <div class="command-pill"><span class="cmd-icon">⏱️</span><div class="cmd-info"><div class="cmd-name">/seek</div><div class="cmd-desc">Loncat ke timestamp</div></div></div>
        <div class="command-pill"><span class="cmd-icon">🔊</span><div class="cmd-info"><div class="cmd-name">/volume</div><div class="cmd-desc">Atur volume 0-200</div></div></div>
        <div class="command-pill"><span class="cmd-icon">🔂</span><div class="cmd-info"><div class="cmd-name">/loop</div><div class="cmd-desc">Loop lagu aktif</div></div></div>
        <div class="command-pill"><span class="cmd-icon">🔁</span><div class="cmd-info"><div class="cmd-name">/loopqueue</div><div class="cmd-desc">Loop seluruh queue</div></div></div>
        <div class="command-pill"><span class="cmd-icon">⏰</span><div class="cmd-info"><div class="cmd-name">/247</div><div class="cmd-desc">Mode 24/7 non-stop</div></div></div>
        <div class="command-pill"><span class="cmd-icon">📋</span><div class="cmd-info"><div class="cmd-name">/queue</div><div class="cmd-desc">Lihat antrian lagu</div></div></div>
        <div class="command-pill"><span class="cmd-icon">🗑️</span><div class="cmd-info"><div class="cmd-name">/clear</div><div class="cmd-desc">Hapus semua queue</div></div></div>
        <div class="command-pill"><span class="cmd-icon">❌</span><div class="cmd-info"><div class="cmd-name">/remove</div><div class="cmd-desc">Hapus lagu tertentu</div></div></div>
        <div class="command-pill"><span class="cmd-icon">🔀</span><div class="cmd-info"><div class="cmd-name">/shuffle</div><div class="cmd-desc">Acak queue</div></div></div>
        <div class="command-pill"><span class="cmd-icon">↕️</span><div class="cmd-info"><div class="cmd-name">/move</div><div class="cmd-desc">Pindah posisi lagu</div></div></div>
        <div class="command-pill"><span class="cmd-icon">📁</span><div class="cmd-info"><div class="cmd-name">/playlist</div><div class="cmd-desc">Kelola playlist</div></div></div>
        <div class="command-pill"><span class="cmd-icon">🔍</span><div class="cmd-info"><div class="cmd-name">/search</div><div class="cmd-desc">Cari & pilih lagu</div></div></div>
        <div class="command-pill"><span class="cmd-icon">🎵</span><div class="cmd-info"><div class="cmd-name">/nowplaying</div><div class="cmd-desc">Info lagu berjalan</div></div></div>
        <div class="command-pill"><span class="cmd-icon">🎛️</span><div class="cmd-info"><div class="cmd-name">/filter</div><div class="cmd-desc">Efek audio</div></div></div>
        <div class="command-pill"><span class="cmd-icon">▶️</span><div class="cmd-info"><div class="cmd-name">/autoplay</div><div class="cmd-desc">Lanjut otomatis</div></div></div>
        <div class="command-pill"><span class="cmd-icon">📥</span><div class="cmd-info"><div class="cmd-name">/join</div><div class="cmd-desc">Masuk voice channel</div></div></div>
