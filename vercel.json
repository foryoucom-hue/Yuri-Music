{
  "name": "yuri-music",
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/:all*(js|css|png|jpg|jpeg|gif|ico|svg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/:all*.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],

  "rewrites": [
    { "source": "/auth/discord", "destination": "/api/auth/discord" },
    { "source": "/auth/callback", "destination": "/auth_callback.html" }
  ],

  "redirects": [
    { "source": "/home", "destination": "/index.html", "permanent": true },
    { "source": "/login", "destination": "/login.html", "permanent": true }
  ]
}
