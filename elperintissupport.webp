<script>
/* ═══════════════════════════════════════
   FAST PRELOADER — Total ~2 seconds
═══════════════════════════════════════ */
(function() {
  const logo      = document.getElementById('loaderLogo');
  const sub       = document.getElementById('loaderSub');
  const bar       = document.getElementById('loaderBar');
  const progress  = document.getElementById('loaderProgress');
  const preloader = document.getElementById('preloader');
  const wrapper   = document.getElementById('page-wrapper');
  const navbar    = document.getElementById('navbar');
  const sidebar   = document.getElementById('sidebar');
  const content   = document.getElementById('docsContent');

  const steps = [
    document.getElementById('step1'),
    document.getElementById('step2'),
    document.getElementById('step3'),
    document.getElementById('step4'),
    document.getElementById('step5'),
  ];

  const stepTimes   = [0, 300, 600, 900, 1200]; // ms each step appears
  const progressPct = [15, 35, 60, 80, 100];
  const doneBefore  = (i) => { if(i>0) { steps[i-1].classList.remove('active'); steps[i-1].classList.add('done'); } };

  // Show logo immediately
  setTimeout(() => { logo.classList.add('show'); sub.classList.add('show'); bar.classList.add('show'); }, 50);

  stepTimes.forEach((t, i) => {
    setTimeout(() => {
      doneBefore(i);
      steps[i].classList.add('active');
      progress.style.width = progressPct[i] + '%';
    }, t + 100);
  });

  // Finish at 1.8s
  setTimeout(() => {
    preloader.classList.add('hidden');
    wrapper.classList.add('show');
    navbar.classList.add('show');
    setTimeout(() => { sidebar.classList.add('show'); }, 100);
    setTimeout(() => { content.classList.add('show'); }, 200);
  }, 1800);
})();

/* ═══ STARS ═══ */
function createStars() {
  const container = document.getElementById('stars');
  for(let i=0;i<180;i++){
    const s = document.createElement('div');
    s.className = 'star';
    const sz = Math.random()*3+0.8;
    s.style.cssText = `width:${sz}px;height:${sz}px;left:${Math.random()*100}vw;top:${Math.random()*100}vh;animation-delay:${Math.random()*7}s;`;
    container.appendChild(s);
  }
}
createStars();

/* ═══ METEORS ═══ */
function spawnMeteor() {
  const m = document.createElement('div');
  m.className = 'meteor';
  const x = 75 + Math.random()*20, y = -20 - Math.random()*30;
  const dur = 3.5 + Math.random()*4;
  m.style.cssText = `left:${x}vw;top:${y}vh;animation-duration:${dur}s;`;
  document.body.appendChild(m);
  setTimeout(() => m.remove(), dur*1000+2000);
}
setInterval(spawnMeteor, 800 + Math.random()*1200);
for(let i=0;i<8;i++) setTimeout(spawnMeteor, i*250+Math.random()*400);

/* ═══ DROPDOWN ═══ */
(() => {
  const wrap = document.getElementById('resourcesDropdown');
  if(!wrap) return;
  const btn = wrap.querySelector('.nav-dropbtn');
  wrap.addEventListener('mouseenter', () => wrap.classList.add('open'));
  wrap.addEventListener('mouseleave', () => wrap.classList.remove('open'));
  btn.addEventListener('click', (e) => { e.stopPropagation(); wrap.classList.toggle('open'); });
  document.addEventListener('click', () => wrap.classList.remove('open'));
  document.addEventListener('keydown', e => { if(e.key==='Escape') wrap.classList.remove('open'); });
})();

/* ═══ TABS ═══ */
function switchTab(e, tabId) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  e.currentTarget.classList.add('active');
  document.getElementById(tabId).classList.add('active');
}

/* ═══ COPY CODE ═══ */
function copyCode(btn) {
  const code = btn.closest('.code-block').querySelector('.code-content').textContent;
  navigator.clipboard.writeText(code).then(() => {
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy', 2000);
  });
}

/* ═══ SCROLL ANIMATIONS ═══ */
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.08, rootMargin: '0px 0px -60px 0px' });
document.querySelectorAll('.content-section').forEach(s => observer.observe(s));

/* ═══ SIDEBAR SEARCH ═══ */
document.getElementById('sidebarSearch').addEventListener('input', e => {
  const q = e.target.value.toLowerCase();
  document.querySelectorAll('.sidebar-links li').forEach(li => {
    li.style.display = li.querySelector('a').textContent.toLowerCase().includes(q) ? '' : 'none';
  });
});

/* ═══ ACTIVE LINK TRACKING ═══ */
const sections = document.querySelectorAll('.content-section[id]');
const navLinks = document.querySelectorAll('.sidebar-links a[href^="#"]');
window.addEventListener('scroll', () => {
  let cur = '';
  sections.forEach(s => { if(pageYOffset >= s.offsetTop - 140) cur = s.id; });
  navLinks.forEach(a => {
    a.classList.toggle('active', a.getAttribute('href') === '#'+cur);
  });
}, { passive: true });

/* ═══ SMOOTH SCROLL ═══ */
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    e.preventDefault();
    const t = document.querySelector(a.getAttribute('href'));
    if(t) window.scrollTo({ top: t.getBoundingClientRect().top + pageYOffset - 90, behavior: 'smooth' });
  });
});

/* ═══ QUICK LINK CARDS ═══ */
document.querySelectorAll('.quick-link-card').forEach(card => {
  card.addEventListener('click', e => {
    e.preventDefault();
    const t = document.querySelector(card.getAttribute('href'));
    if(t) window.scrollTo({ top: t.getBoundingClientRect().top + pageYOffset - 90, behavior: 'smooth' });
  });
});
</script>
</body>
</html>
