<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dokumentasi - YURI MUSIC</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Roboto:wght@300;400;700&family=Fira+Code:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      min-height: 100vh;
      background: #000000;
      font-family: 'Roboto', system-ui, sans-serif;
      overflow-x: hidden;
      color: #fff;
    }

/* === PRELOADER === */
#preloader {
  position: fixed;
  inset: 0;
  background: #000;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  transition: opacity 0.6s ease, visibility 0.6s ease;
}
#preloader.hidden { opacity: 0; visibility: hidden; pointer-events: none; }

.loader-logo {
  font-family: 'Orbitron', sans-serif;
  font-size: 6rem;
  font-weight: 900;
  background: linear-gradient(90deg, #00f0ff, #00aaff, #0066ff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: pulse 2s infinite alternate;
  margin-bottom: 20px;
}
@keyframes pulse {
  0%   { transform: scale(1);    opacity: 0.8; }
  100% { transform: scale(1.08); opacity: 1;   }
}
.loader-text {
  font-size: 1.8rem;
  color: #a78bfa;
  letter-spacing: 4px;
  margin-bottom: 30px;
}
.loader-bar {
  width: 300px;
  height: 6px;
  background: rgba(168,139,250,0.2);
  border-radius: 3px;
  overflow: hidden;
}
.loader-progress {
  width: 0;
  height: 100%;
  background: linear-gradient(90deg, #a78bfa, #c084fc);
  animation: loading 1.8s ease-in-out forwards;
}
@keyframes loading {
  0%   { width: 0; }
  100% { width: 100%; }
}

    .loader-subtitle {
      font-size: 1rem;
      color: #a78bfa;
      letter-spacing: 5px;
      text-transform: uppercase;
      opacity: 0;
      transition: opacity 0.4s ease 0.2s;
      margin-bottom: 30px;
    }
    .loader-subtitle.show { opacity: 1; }

    .loader-steps {
      display: flex;
      flex-direction: column;
      gap: 8px;
      width: 340px;
      margin-bottom: 28px;
    }
    .loader-step {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 0.9rem;
      color: #666;
      opacity: 0;
      transform: translateX(-15px);
      transition: opacity 0.3s ease, transform 0.3s ease, color 0.3s ease;
    }
    .loader-step.active { opacity: 1; transform: translateX(0); color: #a78bfa; }
    .loader-step.done   { opacity: 1; transform: translateX(0); color: #4ade80; }

    .step-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      background: currentColor;
      flex-shrink: 0;
      box-shadow: 0 0 8px currentColor;
    }

    .loader-bar-wrap {
      width: 340px;
      height: 4px;
      background: rgba(168,85,247,0.15);
      border-radius: 2px;
      overflow: hidden;
      opacity: 0;
      transition: opacity 0.3s ease 0.1s;
    }
    .loader-bar-wrap.show { opacity: 1; }
    .loader-progress {
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, #7c3aed, #c084fc);
      border-radius: 2px;
      transition: width 0.4s ease;
      box-shadow: 0 0 10px rgba(192,132,252,0.7);
    }

    /* === PAGE WRAPPER — hidden until loaded === */
    #page-wrapper {
      opacity: 0;
      transition: opacity 0.5s ease;
    }
    #page-wrapper.show { opacity: 1; }

    /* === NAVBAR === */
    .navbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: 70px;
      background: rgba(5, 5, 15, 0.88);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(120,100,255,0.12);
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 50px;
      transform: translateY(-70px);
      transition: transform 0.5s ease;
    }
    .navbar.show { transform: translateY(0); }

    .logo {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.9rem;
      font-weight: 900;
      background: linear-gradient(90deg, #c084fc, #7c3aed, #a78bfa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      text-shadow: 0 0 15px rgba(168,85,247,0.6);
      letter-spacing: 3px;
      text-decoration: none;
    }

    .nav-menu { display: flex; gap: 40px; align-items: center; }
    .nav-menu a {
      color: #d0d0ff;
      text-decoration: none;
      font-size: 1rem;
      font-weight: 500;
      transition: all 0.3s ease;
      position: relative;
    }
    .nav-menu a:hover { color: #fff; }
    .nav-menu a::after {
      content: '';
      position: absolute;
      width: 0; height: 2px;
      bottom: -6px; left: 0;
      background: linear-gradient(90deg, #c084fc, #a78bfa);
      transition: width 0.4s ease;
    }
    .nav-menu a:hover::after { width: 100%; }

    .nav-actions { display: flex; gap: 16px; }
    .btn-action {
      padding: 9px 24px;
      border-radius: 50px;
      font-size: 0.95rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.3s ease;
    }
    .btn-premium {
      background: linear-gradient(135deg, #7c3aed, #c084fc);
      color: white;
      box-shadow: 0 0 20px rgba(168,85,247,0.4);
    }
    .btn-premium:hover { transform: translateY(-2px); box-shadow: 0 0 30px rgba(168,85,247,0.7); }
    .btn-support {
      background: transparent;
      color: #d0d0ff;
      border: 1px solid rgba(168,85,247,0.5);
    }
    .btn-support:hover { background: rgba(168,85,247,0.12); color: #fff; }

    /* === DROPDOWN === */
    .nav-dropdown { position: relative; display: flex; align-items: center; }
    .nav-dropbtn {
      background: transparent; border: none;
      color: #d0d0ff; font-size: 1rem; font-weight: 500;
      cursor: pointer; transition: all 0.3s ease;
      position: relative; padding: 0; display: flex; align-items: center; gap: 8px;
    }
    .nav-dropbtn:hover { color: #fff; }
    .nav-dropbtn::after {
      content:''; position:absolute;
      width:0; height:2px; bottom:-6px; left:0;
      background: linear-gradient(90deg, #c084fc, #a78bfa);
      transition: width 0.4s ease;
    }
    .nav-dropdown:hover .nav-dropbtn::after { width:100%; }
    .dropdown-panel {
      position: absolute;
      top: calc(100% + 18px); left: 0;
      width: 320px; padding: 12px;
      border-radius: 14px;
      background: rgba(10,10,18,0.92);
      border: 1px solid rgba(168,85,247,0.20);
      box-shadow: 0 25px 80px rgba(0,0,0,0.70);
      backdrop-filter: blur(14px);
      transform: translateY(-10px);
      opacity: 0; visibility: hidden;
      transition: all 0.25s ease; z-index: 2000;
    }
    .nav-dropdown.open .dropdown-panel { transform: translateY(0); opacity: 1; visibility: visible; }
    .dropdown-item {
      display: flex; align-items: center; gap: 12px;
      padding: 11px; border-radius: 10px;
      text-decoration: none; transition: all 0.25s ease;
    }
    .dropdown-item:hover { background: rgba(168,85,247,0.10); border: 1px solid rgba(168,85,247,0.18); }
    .dropdown-ico {
      width: 36px; height: 36px; border-radius: 9px;
      background: rgba(168,85,247,0.12);
      border: 1px solid rgba(168,85,247,0.22);
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem; color: #fff; flex: 0 0 auto;
    }
    .dropdown-text { display: flex; flex-direction: column; gap: 2px; }
    .dropdown-title { font-weight: 700; color: #eaeaff; font-size: 1rem; }
    .dropdown-sub { color: #9aa0c6; font-size: 0.88rem; }

    /* === STARS === */
    .stars {
      position: fixed; inset: 0;
      pointer-events: none; z-index: -1;
    }
    .star {
      position: absolute; background: #ffffff;
      border-radius: 50%;
      box-shadow: 0 0 6px rgba(255,255,255,0.8);
      animation: twinkle 6s infinite alternate;
    }
    @keyframes twinkle {
      0%,100% { opacity: 0.4; transform: scale(0.8); }
      50%      { opacity: 1;   transform: scale(1.2); }
    }
    .meteor {
      position: absolute;
      width: 4px; height: 4px;
      background: #fff; border-radius: 50%;
      box-shadow: 0 0 15px 5px rgba(255,255,255,0.8);
      transform: translate(-50%,-50%) rotate(45deg);
      pointer-events: none;
      animation: meteor linear forwards;
    }
    .meteor::after {
      content: ''; position: absolute;
      top: 50%; left: -180px;
      width: 180px; height: 2.5px;
      background: linear-gradient(to left, transparent, rgba(255,255,255,0.8));
      transform: translateY(-50%);
      filter: blur(1.5px);
    }
    @keyframes meteor {
      0%   { transform: translate(-50%,-50%) translate(0,0) rotate(45deg); opacity:1; }
      100% { transform: translate(-50%,-50%) translate(-1100px,1100px) rotate(45deg); opacity:0; }
    }

    /* === DOCS LAYOUT === */
    .docs-wrapper {
      display: flex;
      margin-top: 70px;
      min-height: calc(100vh - 70px);
    }

    /* === SIDEBAR === */
    .docs-sidebar {
      width: 300px;
      background: rgba(10,8,20,0.85);
      backdrop-filter: blur(12px);
      border-right: 1px solid rgba(168,85,247,0.2);
      padding: 35px 18px;
      position: sticky;
      top: 70px;
      height: calc(100vh - 70px);
      overflow-y: auto;
      z-index: 100;
      transform: translateX(-30px);
      opacity: 0;
      transition: transform 0.5s ease 0.1s, opacity 0.5s ease 0.1s;
    }
    .docs-sidebar.show { transform: translateX(0); opacity: 1; }
    .docs-sidebar::-webkit-scrollbar { width: 4px; }
    .docs-sidebar::-webkit-scrollbar-thumb { background: rgba(168,85,247,0.4); border-radius: 2px; }

    .sidebar-search { position: relative; margin-bottom: 25px; }
    .sidebar-search input {
      width: 100%; padding: 11px 38px 11px 14px;
      background: rgba(168,85,247,0.08);
      border: 1px solid rgba(168,85,247,0.25);
      border-radius: 10px; color: #d0d0ff;
      font-size: 0.9rem; outline: none; transition: all 0.3s ease;
    }
    .sidebar-search input:focus {
      background: rgba(168,85,247,0.12);
      border-color: #a78bfa;
      box-shadow: 0 0 16px rgba(168,85,247,0.25);
    }
    .sidebar-search input::placeholder { color: #8080a0; }
    .sidebar-search-icon { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); color: #8080a0; }

    .sidebar-section { margin-bottom: 25px; }
    .sidebar-section-title {
      font-family: 'Orbitron', sans-serif;
      font-size: 0.78rem; font-weight: 700;
      color: #a78bfa; text-transform: uppercase;
      letter-spacing: 1.5px; margin-bottom: 10px; padding-left: 6px;
    }
    .sidebar-links { list-style: none; display: flex; flex-direction: column; gap: 3px; }
    .sidebar-links li a {
      display: flex; align-items: center; gap: 10px;
      padding: 9px 10px; color: #b0b0d0;
      text-decoration: none; border-radius: 8px;
      font-size: 0.9rem; transition: all 0.25s ease;
    }
    .sidebar-links li a:hover { background: rgba(168,85,247,0.12); color: #fff; transform: translateX(4px); }
    .sidebar-links li a.active {
      background: linear-gradient(135deg, rgba(124,58,237,0.25), rgba(192,132,252,0.25));
      color: #fff; border-left: 3px solid #a78bfa; font-weight: 600;
    }
    .sidebar-icon { font-size: 1.1rem; flex-shrink: 0; }

    /* === MAIN CONTENT === */
    .docs-content {
      flex: 1; padding: 55px 70px 100px;
      max-width: 1100px;
      opacity: 0; transform: translateY(30px);
      transition: opacity 0.5s ease 0.2s, transform 0.5s ease 0.2s;
    }
    .docs-content.show { opacity: 1; transform: translateY(0); }

    .docs-header { margin-bottom: 45px; }
    .docs-breadcrumb {
      display: flex; align-items: center; gap: 8px;
      color: #8080a0; font-size: 0.88rem; margin-bottom: 18px;
    }
    .docs-breadcrumb a { color: #a78bfa; text-decoration: none; }
    .docs-breadcrumb a:hover { color: #c084fc; }

    .docs-title {
      font-family: 'Orbitron', sans-serif;
      font-size: 3.5rem; font-weight: 900;
      background: linear-gradient(90deg, #a78bfa, #c084fc, #7c3aed);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      margin-bottom: 18px; letter-spacing: 2px;
    }
    .docs-subtitle { font-size: 1.2rem; color: #b0b0d0; line-height: 1.8; max-width: 750px; }
    .docs-meta { display: flex; gap: 20px; margin-top: 22px; flex-wrap: wrap; }
    .meta-badge {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 7px 14px;
      background: rgba(168,85,247,0.1);
      border: 1px solid rgba(168,85,247,0.3);
      border-radius: 20px; color: #b0b0d0; font-size: 0.88rem;
    }

    /* === CONTENT SECTIONS === */
    .content-section {
      background: rgba(15,10,45,0.65);
      backdrop-filter: blur(18px);
      border: 1px solid rgba(168,85,247,0.35);
      border-radius: 24px;
      padding: 45px;
      margin-bottom: 35px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.7);
      opacity: 0; transform: translateY(40px);
      transition: opacity 0.6s ease, transform 0.6s ease, box-shadow 0.4s ease;
    }
    .content-section.visible { opacity: 1; transform: translateY(0); }
    .content-section:hover { box-shadow: 0 25px 80px rgba(0,0,0,0.8), 0 0 30px rgba(168,85,247,0.1); }

    .section-title {
      font-family: 'Orbitron', sans-serif;
      font-size: 2rem; font-weight: 700;
      color: #fff; margin-bottom: 22px;
      display: flex; align-items: center; gap: 14px;
    }
    .section-icon {
      width: 46px; height: 46px;
      background: linear-gradient(135deg, #7c3aed, #c084fc);
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem;
      box-shadow: 0 0 18px rgba(168,85,247,0.4);
    }
    .section-text { color: #d0d0e0; font-size: 1.05rem; line-height: 1.9; margin-bottom: 18px; }
    .section-text strong { color: #fff; font-weight: 600; }

    /* === COMMAND CARDS === */
    .command-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 18px; margin-top: 28px;
    }
    .command-card {
      background: rgba(168,85,247,0.07);
      border: 1px solid rgba(168,85,247,0.22);
      border-radius: 14px; padding: 22px;
      transition: all 0.3s cubic-bezier(0.34,1.56,0.64,1);
      cursor: pointer;
    }
    .command-card:hover {
      background: rgba(168,85,247,0.14);
      border-color: #a78bfa;
      transform: translateY(-5px);
      box-shadow: 0 12px 35px rgba(168,85,247,0.28);
    }
    .command-name {
      font-family: 'Fira Code', monospace;
      font-size: 1.2rem; font-weight: 600;
      color: #c084fc; margin-bottom: 10px;
      display: flex; align-items: center; gap: 9px;
    }
    .command-badge {
      font-size: 0.72rem; padding: 2px 8px;
      border-radius: 6px; font-family: 'Roboto', sans-serif;
      font-weight: 700; letter-spacing: 0.5px;
    }
    .badge-free { background: rgba(74,222,128,0.15); color: #4ade80; border: 1px solid rgba(74,222,128,0.3); }
    .badge-premium { background: rgba(251,191,36,0.15); color: #fbbf24; border: 1px solid rgba(251,191,36,0.3); }
    .command-desc { color: #b0b0d0; font-size: 0.95rem; line-height: 1.6; margin-bottom: 12px; }
    .command-usage {
      font-family: 'Fira Code', monospace;
      font-size: 0.85rem; color: #8080a0;
      background: rgba(0,0,0,0.4);
      padding: 7px 11px; border-radius: 7px;
      border-left: 3px solid #a78bfa;
    }

    /* === TABS === */
    .tabs { display: flex; gap: 8px; margin-bottom: 25px; flex-wrap: wrap; }
    .tab-btn {
      padding: 9px 22px;
      background: rgba(168,85,247,0.08);
      border: 1px solid rgba(168,85,247,0.22);
      border-radius: 25px; color: #b0b0d0;
      font-size: 0.92rem; cursor: pointer;
      transition: all 0.25s ease;
    }
    .tab-btn.active, .tab-btn:hover {
      background: rgba(168,85,247,0.22);
      border-color: #a78bfa; color: #fff;
    }
    .tab-panel { display: none; }
    .tab-panel.active { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 18px; }

    /* === CODE BLOCKS === */
    .code-block {
      position: relative;
      background: rgba(0,0,0,0.6);
      border: 1px solid rgba(168,85,247,0.3);
      border-radius: 14px; padding: 22px;
      margin: 22px 0; overflow-x: auto;
    }
    .code-header {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 14px; padding-bottom: 14px;
      border-bottom: 1px solid rgba(168,85,247,0.2);
    }
    .code-lang { font-family: 'Fira Code', monospace; font-size: 0.82rem; color: #a78bfa; text-transform: uppercase; letter-spacing: 1px; }
    .code-copy-btn {
      padding: 5px 12px;
      background: rgba(168,85,247,0.15);
      border: 1px solid rgba(168,85,247,0.3);
      border-radius: 7px; color: #b0b0d0;
      font-size: 0.82rem; cursor: pointer;
      transition: all 0.25s ease;
    }
    .code-copy-btn:hover { background: rgba(168,85,247,0.25); color: #fff; }
    .code-content { font-family: 'Fira Code', monospace; font-size: 0.92rem; line-height: 1.7; color: #d0d0ff; }
    .code-content .keyword { color: #c084fc; }
    .code-content .string  { color: #4ade80; }
    .code-content .comment { color: #6b7280; }

    /* === INFO BOXES === */
    .info-box {
      display: flex; gap: 18px; align-items: flex-start;
      padding: 22px; border-radius: 14px; margin: 22px 0;
    }
    .info-box.tip     { background: rgba(74,222,128,0.1);  border: 1px solid rgba(74,222,128,0.3); }
    .info-box.warning { background: rgba(251,191,36,0.1);  border: 1px solid rgba(251,191,36,0.3); }
    .info-box.danger  { background: rgba(239,68,68,0.1);   border: 1px solid rgba(239,68,68,0.3); }
    .info-box.info    { background: rgba(96,165,250,0.1);  border: 1px solid rgba(96,165,250,0.3); }
    .info-icon { font-size: 1.8rem; flex-shrink: 0; }
    .info-title { font-weight: 700; font-size: 1.1rem; color: #fff; margin-bottom: 6px; }
    .info-text  { color: #d0d0e0; line-height: 1.7; }

    /* === STEPS === */
    .steps-list { list-style: none; counter-reset: step-counter; }
    .step-item { display: flex; gap: 22px; margin-bottom: 30px; position: relative; }
    .step-item:not(:last-child)::before {
      content: ''; position: absolute;
      left: 22px; top: 55px;
      width: 2px; height: calc(100% - 35px);
      background: linear-gradient(to bottom, rgba(168,85,247,0.5), transparent);
    }
    .step-number {
      counter-increment: step-counter;
      width: 46px; height: 46px;
      background: linear-gradient(135deg, #7c3aed, #c084fc);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Orbitron', sans-serif;
      font-size: 1.3rem; font-weight: 900; flex-shrink: 0;
      box-shadow: 0 0 20px rgba(168,85,247,0.5);
    }
    .step-number::before { content: counter(step-counter); }
    .step-content { flex: 1; padding-top: 4px; }
    .step-title { font-size: 1.2rem; font-weight: 700; color: #fff; margin-bottom: 8px; }
    .step-desc { color: #d0d0e0; line-height: 1.8; }

    /* === QUICK LINKS === */
    .quick-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 18px; margin-top: 25px; }
    .quick-link-card {
      background: linear-gradient(135deg, rgba(124,58,237,0.15), rgba(192,132,252,0.15));
      border: 1px solid rgba(168,85,247,0.4);
      border-radius: 16px; padding: 28px;
      text-decoration: none;
      transition: all 0.35s cubic-bezier(0.34,1.56,0.64,1);
      display: flex; flex-direction: column; gap: 14px;
      cursor: pointer; position: relative; overflow: hidden;
    }
    .quick-link-card:hover {
      transform: translateY(-8px) scale(1.02);
      box-shadow: 0 20px 50px rgba(168,85,247,0.45);
      border-color: #c084fc;
    }
    .quick-link-icon {
      width: 56px; height: 56px;
      background: linear-gradient(135deg, #7c3aed, #c084fc);
      border-radius: 13px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.9rem;
      box-shadow: 0 0 18px rgba(168,85,247,0.4);
      transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
    }
    .quick-link-card:hover .quick-link-icon { transform: rotate(360deg) scale(1.1); }
    .quick-link-title {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.3rem; font-weight: 700; color: #fff;
      transition: all 0.3s ease;
    }
    .quick-link-card:hover .quick-link-title { color: #c084fc; }
    .quick-link-desc { color: #b0b0d0; line-height: 1.6; }

    /* === FAQ === */
    .faq-item {
      background: rgba(168,85,247,0.08);
      padding: 22px; border-radius: 14px;
      border-left: 4px solid #a78bfa; margin-bottom: 20px;
      cursor: pointer; transition: all 0.3s ease;
    }
    .faq-item:hover { background: rgba(168,85,247,0.12); }
    .faq-question { color: #fff; font-size: 1.2rem; font-weight: 700; margin-bottom: 10px; }
    .faq-answer { color: #d0d0e0; line-height: 1.8; }
    .faq-answer a { color: #a78bfa; }

    /* === FOOTER === */
    .footer-section {
      background: rgba(10,8,20,0.95);
      border-top: 1px solid rgba(168,85,247,0.2);
      padding: 70px 60px 35px;
      margin-top: 100px;
    }
    .footer-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 50px; }
    .footer-brand { display: flex; align-items: center; gap: 18px; }
    .footer-logo-container {
      width: 70px; height: 70px; border-radius: 18px; overflow: hidden;
      border: 2px solid rgba(168,85,247,0.3); box-shadow: 0 0 18px rgba(168,85,247,0.3);
    }
    .footer-logo-img { width: 100%; height: 100%; object-fit: cover; }
    .footer-brand-name {
      font-family: 'Orbitron', sans-serif; font-size: 1.8rem; font-weight: 900;
      background: linear-gradient(90deg, #a78bfa, #c084fc);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: 2px;
    }
    .footer-brand-tagline { font-size: 0.92rem; color: #9090b0; }
    .footer-stats { display: flex; gap: 50px; }
    .footer-stat-number { font-size: 2.2rem; font-weight: 700; color: #fff; font-family: 'Orbitron', sans-serif; }
    .footer-stat-label { font-size: 0.88rem; color: #9090b0; text-transform: uppercase; letter-spacing: 1px; }
    .footer-divider { height: 1px; background: linear-gradient(90deg, transparent, rgba(168,85,247,0.3), transparent); margin: 50px 0; }
    .footer-content { display: flex; gap: 80px; margin-bottom: 50px; }
    .footer-column { flex: 1; }
    .footer-heading { font-family: 'Orbitron', sans-serif; font-size: 1.2rem; font-weight: 700; color: #fff; margin-bottom: 22px; }
    .footer-links { list-style: none; display: flex; flex-direction: column; gap: 14px; }
    .footer-links li a { color: #b0b0d0; text-decoration: none; font-size: 1rem; transition: all 0.3s ease; display: inline-block; }
    .footer-links li a:hover { color: #fff; transform: translateX(4px); }
    .footer-bottom { display: flex; justify-content: space-between; align-items: center; padding-top: 35px; border-top: 1px solid rgba(168,85,247,0.15); }
    .footer-copyright { font-size: 0.95rem; color: #8080a0; }
    .footer-socials { display: flex; gap: 18px; }
    .footer-social-link {
      width: 42px; height: 42px; border-radius: 50%;
      background: rgba(168,85,247,0.1); border: 1px solid rgba(168,85,247,0.3);
      display: flex; align-items: center; justify-content: center;
      color: #b0b0d0; transition: all 0.35s ease; text-decoration: none;
    }
    .footer-social-link:hover { background: rgba(168,85,247,0.25); color: #fff; transform: translateY(-3px); box-shadow: 0 6px 20px rgba(168,85,247,0.35); }

    @media (max-width: 1024px) {
      .docs-sidebar { display: none; }
      .docs-content { padding: 35px 25px; }
      .docs-title { font-size: 2.5rem; }
      .footer-top { flex-direction: column; gap: 30px; }
      .footer-content { flex-direction: column; gap: 30px; }
      .footer-bottom { flex-direction: column; gap: 20px; }
      .nav-menu { display: none; }
    }
    @media (max-width: 768px) {
      .navbar { padding: 0 20px; }
      .content-section { padding: 25px 18px; }
      .command-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
